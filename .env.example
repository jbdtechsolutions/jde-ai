# YouTube Data API v3 Key — required for public channel stats
# Get one at: https://console.cloud.google.com → APIs & Services → Credentials
YOUTUBE_API_KEY=YOUR_API_KEY_HERE

# OAuth credentials file — only needed for channels you own (detailed analytics)
# Download from Google Cloud Console → OAuth 2.0 Client IDs → Desktop app
CLIENT_SECRETS_FILE=client_secrets.json

# Token cache file (auto-created after first OAuth login)
TOKEN_FILE=token.json

# Analytics date range (defaults used if not set)
DEFAULT_START_DAYS_AGO=30
DEFAULT_END_DAYS_AGO=0

# ── WhatsApp notifications (Twilio) ───────────────────────────────────────────
# Sign up at https://www.twilio.com → Messaging → Try WhatsApp Sandbox
# Send the join code from your WhatsApp to +1 415 523 8886 (sandbox only)
TWILIO_ACCOUNT_SID=YOUR_TWILIO_SID_HERE
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN_HERE
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX
